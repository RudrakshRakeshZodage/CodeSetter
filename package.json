{
  "name": "codesetter",
  "version": "1.0.0",
  "description": "AI-powered repository auditing and optimization toolkit — scan any codebase for quality, security, performance, accessibility, testing, and architecture issues.",
  "keywords": [
    "code-quality",
    "security",
    "performance",
    "accessibility",
    "testing",
    "architecture",
    "audit",
    "linting",
    "static-analysis",
    "ai",
    "typescript",
    "react",
    "nextjs",
    "node"
  ],
  "homepage": "https://github.com/RudrakshRakeshZodage/CodeSetter#readme",
  "bugs": {
    "url": "https://github.com/RudrakshRakeshZodage/CodeSetter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RudrakshRakeshZodage/CodeSetter.git"
  },
  "license": "MIT",
  "author": {
    "name": "Rudraksh Zodage",
    "email": "rudraksh@codesetter.dev"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "codesetter": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./scanners": {
      "import": "./dist/scanners/index.mjs",
      "require": "./dist/scanners/index.js",
      "types": "./dist/scanners/index.d.ts"
    },
    "./ai": {
      "import": "./dist/ai/index.mjs",
      "require": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "release": "npm publish --access public"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.9",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.2.0",
    "glob": "^10.4.5",
    "openai": "^4.77.0",
    "ora": "^5.4.1",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
